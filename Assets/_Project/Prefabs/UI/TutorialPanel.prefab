  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041D\u0430 \u043F\u043B\u0430\u043D\u0435\u0442\u0435 <b>Nimbus</b>
    \u043A\u0438\u0441\u043B\u043E\u0440\u043E\u0434 \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E
    \u0440\u0430\u0441\u0445\u043E\u0434\u0443\u0435\u0442\u0441\u044F \u2014 \u0441\u043B\u0435\u0434\u0438
    \u0437\u0430 \u043F\u043E\u043B\u043E\u0441\u043A\u043E\u0439 \u0432 \u0432\u0435\u0440\u0445\u043D\u0435\u0439
    \u0447\u0430\u0441\u0442\u0438 \u044D\u043A\u0440\u0430\u043D\u0430.\n\n\u041F\u043E\u043F\u043E\u043B\u043D\u044F\u0439
    \u0437\u0430\u043F\u0430\u0441 \u0432 <b>\u043A\u0438\u0441\u043B\u043E\u0440\u043E\u0434\u043D\u044B\u0445
    \u043A\u0430\u043F\u0441\u0443\u043B\u0430\u0445</b> (\u043D\u0430\u0436\u043C\u0438
    E \u0440\u044F\u0434\u043E\u043C \u0441 \u043A\u0430\u043F\u0441\u0443\u043B\u043E\u0439).
    \u041F\u043E\u0441\u043B\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u043A\u0430\u043F\u0441\u0443\u043B\u0435 \u043D\u0443\u0436\u043D\u043E \u0432\u0440\u0435\u043C\u044F
    \u043D\u0430 \u043F\u0435\u0440\u0435\u0437\u0430\u0440\u044F\u0434\u043A\u0443.\n\n\u0415\u0441\u043B\u0438
    \u043A\u0438\u0441\u043B\u043E\u0440\u043E\u0434 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u0441\u044F
    \u2014 \u0438\u0433\u0440\u043E\u043A \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
    \u043A <b> \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u043C\u0443 \u0447\u0435\u043A\u043F\u043E\u0438\u043D\u0442\u0443(\u043A
    \u043A\u0430\u043F\u0441\u0443\u043B\u0435, \u043E\u0442\u043A\u0443\u0434\u0430
    \u0431\u0440\u0430\u043B \u043A\u0438\u0441\u043B\u043E\u0440\u043E\u0434 \u0432
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0440\u0430\u0437)</b>
    \u0441 \u043F\u043E\u043B\u043D\u044B\u043C \u0437\u0430\u043F\u0430\u0441\u043E\u043C.\n\n\u041A\u0438\u0441\u043B\u043E\u0440\u043E\u0434
    \u0442\u0440\u0430\u0442\u0438\u0442\u0441\u044F \u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430 \u043F\u043B\u0430\u043D\u0435\u0442\u0435 Nimbus \u0438 \u043D\u0430
    \u0441\u0432\u0430\u043B\u043A\u0435"
  m_isRightToLeft: 0
